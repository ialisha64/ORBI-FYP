# Copy this file to .env and fill in your values

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=orbi_db

# JWT - Change this to a long random secret in production!
SECRET_KEY=orbi-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o-mini

# CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:8082,http://localhost:8083

# Email / SMTP (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Orbi AI

# Frontend URL used in verification links
FRONTEND_URL=http://localhost:8083

# Debug mode
DEBUG=false
