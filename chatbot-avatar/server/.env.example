# ── D-ID API ──────────────────────────────────────────────────────────────────
# Get your free key at https://studio.d-id.com  → Settings → API
DID_API_KEY=your_did_api_key_here

# ── Avatar image ──────────────────────────────────────────────────────────────
# Must be a publicly accessible URL.
# Free option: upload avatar.jpg to https://imgbb.com and paste the direct link.
# Default uses D-ID's built-in presenter if left blank.
AVATAR_IMAGE_URL=

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# If blank, mock responses are used instead.
OPENAI_API_KEY=

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3001
